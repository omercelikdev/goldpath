<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Single explicit feed to avoid inherited-feed conflicts (NU1507).
       In enterprise CI this is overridden to an internal mirror (air-gapped scenario). -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
