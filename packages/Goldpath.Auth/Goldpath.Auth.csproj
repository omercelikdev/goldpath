<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <PackageId>Goldpath.Auth</PackageId>
    <Description>Ring B authentication/authorization composition for the Goldpath enterprise asset: OIDC/JWT bearer (compose your IdP — Keycloak/Entra/Ping; we do not write identity servers) or a minimal API-key handler, secure-by-default fallback policy, token–tenant binding with MultiTenancy, and Mediant [Authorize] composed for command-level checks. Fail-closed everywhere.</Description>
    <RootNamespace>Goldpath</RootNamespace>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../Goldpath.Abstractions/Goldpath.Abstractions.csproj" />
    <PackageReference Include="Mediant.Behaviors" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.JwtBearer" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" />
    <!-- Direct pin lifts the transitive Microsoft.OpenApi 2.0.0 (GHSA-v5pm-xwqc-g5wc). -->
    <PackageReference Include="Microsoft.OpenApi" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
