<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <PackageId>Goldpath.Caching</PackageId>
    <Description>Ring B caching for the Goldpath enterprise asset: Microsoft HybridCache (L1+L2, stampede-protected, tag invalidation) as the app surface and Mediant [Cacheable]/[InvalidatesCache] as the query surface — composed, not wrapped. Goldpath adds the manifest-driven L1/L2 wiring and the tenant-scoped key convention (goldpath:{tenant}:{area}:{key}).</Description>
    <RootNamespace>Goldpath</RootNamespace>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Goldpath.Abstractions/Goldpath.Abstractions.csproj" />
    <PackageReference Include="Mediant.Behaviors" />
    <PackageReference Include="Microsoft.Extensions.Caching.Hybrid" />
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Binder" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.PublicApiAnalyzers" PrivateAssets="all" />
    <AdditionalFiles Include="PublicAPI.Shipped.txt" />
    <AdditionalFiles Include="PublicAPI.Unshipped.txt" />
    <None Include="README.md" Pack="true" PackagePath="/" />
  </ItemGroup>

</Project>
