{
  "stryker-config": {
    "project": "Goldpath.Bulk.csproj",
    "test-projects": ["../tests/Goldpath.Bulk.Tests/Goldpath.Bulk.Tests.csproj"],
    "target-framework": "net10.0",
    "reporters": ["progress", "markdown"],
    "thresholds": {
      "high": 85,
      "low": 75,
      "break": 70
    },
    "mutation-level": "Standard",
    "ignore-methods": ["Log*"],
    "mutate": [
      "!**/GoldpathBulkExtensions.cs",
      "!**/GoldpathBulkMetrics.cs",
      "!**/GoldpathBulkAdminEndpoints.cs"
    ]
  }
}
