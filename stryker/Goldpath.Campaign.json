{
  "stryker-config": {
    "project": "Goldpath.Campaign.csproj",
    "test-projects": [
      "../tests/Goldpath.Campaign.Tests/Goldpath.Campaign.Tests.csproj"
    ],
    "target-framework": "net10.0",
    "reporters": [
      "progress",
      "markdown",
      "json"
    ],
    "thresholds": {
      "high": 85,
      "low": 75,
      "break": 70
    },
    "mutation-level": "Standard",
    "ignore-methods": [
      "Log*"
    ],
    "mutate": [
      "!**/GoldpathCampaignExtensions.cs",
      "!**/GoldpathCampaignMetrics.cs",
      "!**/GoldpathCampaignConsumers.cs",
      "!**/GoldpathCampaignAdminEndpoints.cs"
    ]
  }
}
