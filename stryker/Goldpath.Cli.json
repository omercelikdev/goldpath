{
  "stryker-config": {
    "project": "Goldpath.Cli.csproj",
    "test-projects": [
      "tests/Goldpath.Cli.Tests/Goldpath.Cli.Tests.csproj"
    ],
    "target-framework": "net10.0",
    "reporters": [
      "progress",
      "markdown"
    ],
    "thresholds": {
      "high": 85,
      "low": 75,
      "break": 70
    },
    "mutation-level": "Standard",
    "mutate": [
      "!**/Program.cs",
      "!**/ConsoleProcessRunner.cs"
    ]
  }
}
