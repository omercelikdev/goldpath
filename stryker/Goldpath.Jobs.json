{
  "stryker-config": {
    "project": "Goldpath.Jobs.csproj",
    "test-projects": [
      "tests/Goldpath.Jobs.Tests/Goldpath.Jobs.Tests.csproj"
    ],
    "target-framework": "net10.0",
    "reporters": [
      "progress",
      "markdown"
    ],
    "thresholds": {
      "high": 85,
      "low": 75,
      "break": 70
    },
    "mutation-level": "Standard",
    "ignore-methods": ["Log*"],
    "mutate": [
      "!**/GoldpathJobsExtensions.cs",
      "!**/QuartzStoreModel.cs",
      "!**/GoldpathQuartzAdapter.cs",
      "!**/GoldpathJobHistoryListener.cs",
      "!**/GoldpathJobsFleetRegistry.cs",
      "!**/GoldpathJobsAdminService.cs",
      "!**/GoldpathJobsAdminEndpoints.cs"
    ]
  }
}
