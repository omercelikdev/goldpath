{
  "stryker-config": {
    "project": "Goldpath.Notification.csproj",
    "test-projects": [
      "../tests/Goldpath.Notification.Tests/Goldpath.Notification.Tests.csproj"
    ],
    "target-framework": "net10.0",
    "reporters": [
      "progress",
      "markdown",
      "json"
    ],
    "thresholds": {
      "high": 85,
      "low": 75,
      "break": 70
    },
    "mutation-level": "Standard",
    "ignore-methods": [
      "Log*"
    ],
    "mutate": [
      "!**/GoldpathNotificationExtensions.cs",
      "!**/GoldpathNotificationMetrics.cs",
      "!**/GoldpathNotificationChannels.cs",
      "!**/GoldpathNotificationAdminEndpoints.cs"
    ]
  }
}